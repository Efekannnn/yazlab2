# ============================================
# YazLab2 - Environment Variables Template
# Bu dosyayi .env olarak kopyala ve degerleri guncelle
# cp .env.example .env
# ============================================

# --- JWT Configuration ---
JWT_SECRET=buraya-guclu-bir-secret-yaz
JWT_EXPIRES_IN=1h

# --- Service Ports ---
DISPATCHER_PORT=3000
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003

# --- Service URLs (Docker internal network) ---
AUTH_SERVICE_URL=http://auth-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
ORDER_SERVICE_URL=http://order-service:3003

# --- MongoDB Connection Strings ---
DISPATCHER_MONGO_URI=mongodb://mongo-dispatcher:27017/dispatcher_db
AUTH_MONGO_URI=mongodb://mongo-auth:27017/auth_db
PRODUCT_MONGO_URI=mongodb://mongo-product:27017/product_db
ORDER_MONGO_URI=mongodb://mongo-order:27017/order_db

# --- MongoDB Root Credentials ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
